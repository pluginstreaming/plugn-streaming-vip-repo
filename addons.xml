<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.plugnstreaming" name="PLUGN STREAMING VIP" version="2.0.4" provider-name="PLUGN Team">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.9.1"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="pt_BR">PLUGN STREAMING VIP - Multiplos Servidores IPTV</summary>
        <description lang="pt_BR">PLUGN STREAMING VIP - TV ao vivo, filmes e series com qualidade HD. Suporte a multiplos servidores com troca dinamica. Acesso protegido por PIN.</description>
        <disclaimer lang="pt_BR">Este addon e fornecido como esta. O usuario e responsavel por cumprir com as leis locais.</disclaimer>
        <language>pt_BR</language>
        <platform>all</platform>
        <license>GPL-2.0</license>
        <assets>
            <icon>icon.jpg</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="repository.plugnstreaming.vip" name="PLUGN STREAMING VIP Repository" version="1.0.0" provider-name="PLUGN Team">
    <extension point="xbmc.addon.repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/pluginstreaming/plugn-streaming-vip-repo/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/pluginstreaming/plugn-streaming-vip-repo/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/pluginstreaming/plugn-streaming-vip-repo/main/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="pt_BR">Repositório oficial do addon PLUGN STREAMING VIP.</summary>
        <description lang="pt_BR">Repositório Kodi para distribuição e atualização automática do addon PLUGN STREAMING VIP.</description>
        <platform>all</platform>
        <language>pt_BR</language>
        <license>GPL-2.0</license>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
